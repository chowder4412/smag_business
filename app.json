{
  "expo": {
    "name": "Smag Business",
    "slug": "smag-business",
    "scheme": "smag-business",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a0d06"
    },
    "ios": {
      "bundleIdentifier": "com.smag.business",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Smag Business uses your location to update delivery tracking."
      }
    },
    "android": {
      "package": "com.smag.business",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      ["expo-notifications", {
        "icon": "./assets/icon.png",
        "color": "#ff7941",
        "sounds": []
      }],
      ["expo-location", {
        "locationWhenInUsePermission": "Allow Smag Business to use your location for delivery tracking."
      }],
      ["react-native-maps", { "googleMapsApiKey": "$(GOOGLE_MAPS_API_KEY)" }]
    ],
    "experiments": { "typedRoutes": true }
  }
}
